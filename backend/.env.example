# Database
DATABASE_URL="postgresql://user:password@localhost:5432/omega_afro_shop?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/omega_afro_shop?schema=public"

# Redis (Optional - for caching)
# If not set, app will use in-memory cache
# Local development:
REDIS_URL="redis://localhost:6379"
# Production (Upstash/Redis Cloud):
# REDIS_URL="rediss://default:password@your-redis-host.upstash.io:6379"

# JWT
JWT_SECRET="your-secret-key-change-in-production-use-strong-random-string"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# AWS S3
AWS_S3_BUCKET="omega-afro-shop-images"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="eu-west-2"

# Email (SendGrid or AWS SES)
EMAIL_PROVIDER="sendgrid" # or "ses"
SENDGRID_API_KEY="your_sendgrid_api_key"
EMAIL_FROM="noreply@omegaafroshop.com"
EMAIL_FROM_NAME="OMEGA AFRO SHOP"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+447535316253"

# Application
PORT=4000
NODE_ENV="development" # development | staging | production
# Local:
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"
# Production:
# FRONTEND_URL="https://yourdomain.com"
# API_URL="https://api.yourdomain.com"

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=900
AUTH_RATE_LIMIT_MAX=5

# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this section for production deployment
# Replace all placeholder values with real credentials
#
# Required for production:
# - DATABASE_URL (PostgreSQL)
# - JWT_SECRET (strong random string, min 32 chars)
# - STRIPE_SECRET_KEY (sk_live_...)
# - STRIPE_WEBHOOK_SECRET (whsec_...)
# - STRIPE_PUBLISHABLE_KEY (pk_live_...)
# - FRONTEND_URL (your domain)
# - NODE_ENV=production
#
# Optional but recommended:
# - REDIS_URL (for better performance)
# - AWS credentials (for image uploads)
# - Email provider (for notifications)
# - SMS provider (for order updates)

# Logging
LOG_LEVEL="debug" # error | warn | info | debug

# Email Configuration (Resend SMTP)
# Get your API key from: https://resend.com/api-keys
# The API key is used as the SMTP password
RESEND_API_KEY=re_xxxxxxxxxxxxx
FROM_EMAIL=orders@omegaafro.com

# SMTP Settings (automatically configured):
# Host: smtp.resend.com
# Port: 465 (SSL)
# Username: resend
# Password: RESEND_API_KEY (above)
CLEANUP_SECRET_CODE=your-super-secret-code-123