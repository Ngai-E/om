// Prisma Schema for OMEGA AFRO SHOP
// Database: PostgreSQL 15+


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?   // Optional for guest users
  firstName     String
  lastName      String
  phone         String?
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  isGuest       Boolean   @default(false) // Guest checkout users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  // Relations
  customerProfile CustomerProfile?
  addresses       Address[]
  carts           Cart[]
  orders          Order[]
  auditLogs       AuditLog[]
  reviews         Review[]

  @@index([email])
  @@index([role])
  @@index([phone])
  @@map("users")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  PICKER
  DRIVER
}

model CustomerProfile {
  id                String        @id @default(uuid())
  userId            String        @unique
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth       DateTime?
  marketingOptIn    Boolean       @default(false)
  smsOptIn          Boolean       @default(false)
  preferredLanguage String        @default("en")
  loyaltyPoints     Int           @default(0) // Phase 2
  
  // Risk Management
  riskLevel         RiskLevel     @default(LOW)
  isBlocked         Boolean       @default(false)
  blockedReason     String?
  blockedAt         DateTime?
  blockedBy         String?       // Admin user ID who blocked
  adminNotes        String?       // Internal notes about customer
  tags              String[]      @default([]) // Custom tags for categorization
  
  // Metrics
  totalOrders       Int           @default(0)
  totalSpent        Float         @default(0)
  cancelledOrders   Int           @default(0)
  returnedOrders    Int           @default(0)
  lastOrderDate     DateTime?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([riskLevel])
  @@index([isBlocked])
  @@map("customer_profiles")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Address {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  label          String? // e.g., "Home", "Work"
  line1          String
  line2          String?
  city           String
  county         String?
  postcode       String
  country        String        @default("GB")
  isDefault      Boolean       @default(false)
  deliveryZoneId String?
  deliveryZone   DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  orders Order[]

  @@index([userId])
  @@index([postcode])
  @@map("addresses")
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Category {
  id              String     @id @default(uuid())
  name            String
  slug            String     @unique
  description     String?
  image           String? // S3 URL
  parentId        String?
  parent          Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryHierarchy")
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  isQuickCategory Boolean    @default(false) // Show on homepage quick categories
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isQuickCategory])
  @@map("categories")
}

model Product {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  description     String?
  price           Decimal        @db.Decimal(10, 2)
  compareAtPrice  Decimal?       @db.Decimal(10, 2) // Original price (for sales)
  sku             String?        @unique
  barcode         String?
  unitSize        String? // e.g., "1kg", "500g"
  origin          String? // Country of origin
  ingredients     String?
  allergens       String?
  nutritionalInfo Json? // Flexible JSON field
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  isActive        Boolean        @default(true)
  isFeatured      Boolean        @default(false)
  isBestSeller    Boolean        @default(false)
  tags            String[] // e.g., ["vegan", "gluten-free", "halal"]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime? // Soft delete

  // Relations
  inventory  Inventory?
  images     ProductImage[]
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String // S3 URL
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id          String     @id @default(uuid())
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String // e.g., "1kg", "Red", "Large"
  sku         String     @unique
  price       Decimal    @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  stock       Int        @default(0)
  imageUrl    String?    // Optional variant-specific image
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Inventory {
  id                String   @id @default(uuid())
  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(10)
  isTracked         Boolean  @default(true) // If false, always "in stock"
  updatedAt         DateTime @updatedAt

  @@map("inventory")
}

// ============================================
// PRODUCT REVIEWS
// ============================================

model Review {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?      // Optional: Link to order to verify purchase
  rating      Int          // 1-5 stars
  title       String?
  comment     String?
  status      ReviewStatus @default(PENDING)
  approvedBy  String?      // Admin/Staff user ID who approved
  approvedAt  DateTime?
  rejectedBy  String?      // Admin/Staff user ID who rejected
  rejectedAt  DateTime?
  rejectionReason String?
  isVerifiedPurchase Boolean @default(false) // True if linked to an order
  showOnHomepage Boolean @default(false) // True if review should be featured on homepage
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([orderId])
  @@index([showOnHomepage])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// TESTIMONIALS
// ============================================

model Testimonial {
  id          String   @id @default(uuid())
  videoUrl    String   // URL to video (ImgBB/Cloudinary or external)
  thumbnailUrl String? // Optional thumbnail image
  title       String?  // Optional title for the testimonial
  description String?  // Optional description
  sortOrder   Int      @default(0) // For ordering testimonials
  isActive    Boolean  @default(true) // Show/hide testimonial
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("testimonials")
}

// ============================================
// SHOPPING CART
// ============================================

model Cart {
  id        String     @id @default(uuid())
  userId    String? // Null for guest carts
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String? // For guest carts
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime // Auto-expire after 24 hours

  // Relations
  items CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([cartId, productId, variantId]) // Prevent duplicate products/variants in same cart
  @@index([cartId])
  @@map("cart_items")
}

// ============================================
// ORDERS & PAYMENTS
// ============================================

model Order {
  id                String              @id @default(uuid())
  orderNumber       String              @unique // Human-readable (e.g., "ORD-2024-00001")
  userId            String? // Null for guest orders
  user              User?               @relation(fields: [userId], references: [id])
  guestEmail        String? // For guest orders
  guestPhone        String?
  status            OrderStatus         @default(RECEIVED)
  fulfillmentType   FulfillmentType
  subtotal          Decimal             @db.Decimal(10, 2)
  deliveryFee       Decimal             @db.Decimal(10, 2) @default(0)
  total             Decimal             @db.Decimal(10, 2)
  notes             String? // Customer notes
  staffNotes        String? // Internal notes
  isPhoneOrder      Boolean             @default(false) // Created via phone order system
  addressId         String?
  address           Address?            @relation(fields: [addressId], references: [id])
  deliverySlotId    String?
  deliverySlot      DeliverySlot?       @relation(fields: [deliverySlotId], references: [id])
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Promotions & Discounts
  discountTotal     Decimal             @db.Decimal(10, 2) @default(0)
  
  // Relations
  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  promotionRedemptions PromotionRedemption[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([isPhoneOrder])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  RECEIVED
  PICKING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  READY_FOR_COLLECTION
  COLLECTED
  CANCELLED
  REFUNDED
}

enum FulfillmentType {
  DELIVERY
  COLLECTION
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  productName     String // Snapshot at order time
  variantName     String? // Snapshot of variant name
  productPrice    Decimal         @db.Decimal(10, 2)
  quantity        Int
  subtotal        Decimal         @db.Decimal(10, 2)
  substitutedWith String? // Product ID if substituted
  notes           String? // e.g., "customer prefers ripe plantains"

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  notes     String?
  createdBy String? // User ID who made the change
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id                      String        @id @default(uuid())
  orderId                 String        @unique
  order                   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripePaymentIntentId   String?       @unique
  stripePaymentLinkId     String? // Payment link URL for phone orders
  stripeCheckoutSessionId String?       @unique // Checkout session ID for webhook tracking
  amount                  Decimal       @db.Decimal(10, 2)
  currency                String        @default("GBP")
  status                  PaymentStatus @default(PENDING)
  paymentMethod           PaymentMethod
  paidAt                  DateTime?
  refundedAt              DateTime?
  refundAmount            Decimal?      @db.Decimal(10, 2)
  refundReason            String?
  metadata                Json? // Additional Stripe metadata
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([stripePaymentIntentId])
  @@index([stripeCheckoutSessionId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  CASH_ON_DELIVERY
  PAY_IN_STORE
}

// ============================================
// DELIVERY MANAGEMENT
// ============================================

model DeliveryZone {
  id                    String    @id @default(uuid())
  name                  String // e.g., "Bolton Central"
  postcodePrefix        String[] // e.g., ["BL1", "BL2"]
  deliveryFee           Decimal   @db.Decimal(10, 2)
  minOrderValue         Decimal   @db.Decimal(10, 2) @default(0)
  freeDeliveryThreshold Decimal?  @db.Decimal(10, 2)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  addresses Address[]

  @@map("delivery_zones")
}

model DeliverySlot {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  startTime String // e.g., "10:00"
  endTime   String // e.g., "12:00"
  capacity  Int      @default(10)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders Order[]

  @@unique([date, startTime, endTime])
  @@index([date])
  @@map("delivery_slots")
}

model DeliverySlotTemplate {
  id        String   @id @default(cuid())
  dayOfWeek Int // 0=Sunday, 1=Monday, etc.
  startTime String // "09:00"
  endTime   String // "11:00"
  capacity  Int      @default(10)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("delivery_slot_templates")
}

model DeliverySlotOverride {
  id         String   @id @default(cuid())
  date       DateTime // Specific date
  startTime  String
  endTime    String
  capacity   Int
  isDisabled Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("delivery_slot_overrides")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSettings {
  id                    String   @id @default(uuid())
  key                   String   @unique // e.g., "payment_method", "store_name"
  value                 String // JSON string for complex values
  description           String?
  updatedAt             DateTime @updatedAt
  updatedBy             String? // User ID who last updated

  @@map("system_settings")
}

// ============================================
// PROMOTIONS & DISCOUNTS
// ============================================

model Promotion {
  id          String           @id @default(uuid())
  name        String
  description String?
  imageUrl    String? // Promotion banner image
  code        String?          @unique // Optional promo code (null = automatic)
  
  // Status & Scheduling
  status      PromotionStatus  @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  
  // Budget Controls
  budgetType              BudgetType @default(NONE)
  maxTotalDiscountAmount  Decimal?   @db.Decimal(10, 2) // Max £ to give away
  maxTotalRedemptions     Int? // Max number of uses
  maxRedemptionsPerUser   Int? // Max uses per customer
  
  // Eligibility Rules
  minSubtotal             Decimal?        @db.Decimal(10, 2)
  firstOrderOnly          Boolean         @default(false)
  allowedFulfillment      FulfillmentType? // null = any
  allowGuests             Boolean         @default(true)
  
  // Discount Definition
  discountType       DiscountType
  discountValue      Decimal      @db.Decimal(10, 2) // 10 = 10% or £10
  maxDiscountPerOrder Decimal?    @db.Decimal(10, 2) // Cap per order
  
  // Discount Application Target
  applyToSubtotal    Boolean @default(true)
  applyToDeliveryFee Boolean @default(false)
  
  // Stacking
  allowStacking      Boolean @default(false)
  priority           Int     @default(0) // Higher = evaluated first
  
  // Metadata
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  redemptions PromotionRedemption[]
  
  @@index([status])
  @@index([code])
  @@index([startAt, endAt])
  @@map("promotions")
}

model PromotionRedemption {
  id              String   @id @default(uuid())
  promotionId     String
  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String?  // Null for guest orders
  
  discountAmount  Decimal  @db.Decimal(10, 2)
  appliedToSubtotal Decimal @db.Decimal(10, 2) @default(0)
  appliedToDelivery Decimal @db.Decimal(10, 2) @default(0)
  
  createdAt       DateTime @default(now())
  
  @@index([promotionId])
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
  @@map("promotion_redemptions")
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum BudgetType {
  NONE
  TOTAL_DISCOUNT
  TOTAL_USES
  BOTH
}

enum DiscountType {
  PERCENT
  FIXED
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g., "CREATE_PRODUCT", "UPDATE_ORDER"
  entity    String // e.g., "Product", "Order"
  entityId  String // ID of affected entity
  changes   Json? // Before/after snapshot
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// LICENSING & PACKAGING SYSTEM
// ============================================

enum PackageTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

model Package {
  id                String      @id @default(uuid())
  name              String      @unique
  tier              PackageTier
  displayName       String
  description       String?
  price             Decimal     @db.Decimal(10, 2)
  billingCycle      String      @default("monthly") // monthly, yearly, lifetime
  maxOrders         Int?        // null = unlimited
  maxUsers          Int?        // null = unlimited
  maxProducts       Int?        // null = unlimited
  features          Json        // { "promotions": true, "analytics": true, etc. }
  isActive          Boolean     @default(true)
  sortOrder         Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  licenses          License[]

  @@map("packages")
}

model License {
  id                String        @id @default(uuid())
  licenseKey        String        @unique
  packageId         String
  package           Package       @relation(fields: [packageId], references: [id])
  
  // Licensee Information
  companyName       String
  contactEmail      String
  contactName       String?
  domain            String?       // Restrict to specific domain
  
  // Status & Validity
  status            LicenseStatus @default(ACTIVE)
  issuedAt          DateTime      @default(now())
  expiresAt         DateTime?     // null = lifetime
  activatedAt       DateTime?
  lastValidatedAt   DateTime?
  
  // Usage Tracking
  currentOrders     Int           @default(0)
  currentUsers      Int           @default(0)
  currentProducts   Int           @default(0)
  
  // Metadata
  notes             String?
  issuedBy          String?       // Admin who issued
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  usageLogs         LicenseUsageLog[]

  @@index([licenseKey])
  @@index([status])
  @@index([expiresAt])
  @@map("licenses")
}

model LicenseUsageLog {
  id          String   @id @default(uuid())
  licenseId   String
  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  metric      String   // "orders", "users", "products", "api_calls"
  value       Int
  timestamp   DateTime @default(now())
  metadata    Json?    // Additional context

  @@index([licenseId, timestamp])
  @@map("license_usage_logs")
}

model FeatureFlag {
  id            String   @id @default(uuid())
  key           String   @unique // e.g., "promotions", "analytics", "multi_location"
  name          String
  description   String?
  category      String?  // "core", "advanced", "enterprise"
  isEnabled     Boolean  @default(true)
  requiredTier  String?  // Minimum tier required: "STARTER", "PROFESSIONAL", "ENTERPRISE"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("feature_flags")
}
